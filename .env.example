# Sterling Farms login (the email + password you use on chelseareservations.com)
STERLING_EMAIL=
STERLING_PASSWORD=

# Safety toggle. When true, the bot performs every step but stops short of
# clicking the final time-slot link (which is what books the round) and takes
# a screenshot of what it WOULD have booked.
# Default: true. Production should explicitly set false once verified.
DRY_RUN=true

# Tee-time window (24h, HH:MM).
TARGET_TIME_MIN=10:00
TARGET_TIME_MAX=15:00

# Round details.
GOLFERS=2
HOLES=18

# Milliseconds to wait AFTER 5:00:00 AM ET before firing the calendar click.
# Buffer absorbs any server clock skew; increase if 5:00:00.050 is rejected as too early.
RACE_FIRE_BUFFER_MS=50

# Vacation toggle. Any truthy value skips the run cleanly.
# SKIP_NEXT=1

# Local-testing only: skip the wait-until-5am-ET step and fire immediately.
# Never set this in Railway production.
# OVERRIDE_FIRE_NOW=true

# Local-testing only: instead of waiting until 5 AM ET, wait this many milliseconds.
# Useful to verify the wait pattern works without sitting through hours.
# `npm run dev` sets this to 10000 (10 sec) by default.
# SIMULATE_WAIT_MS=10000

# Set to false to see the browser window while it runs. Default true (Railway must stay headless).
# HEADLESS=true

# Log output format: "pretty" (default, human-readable, colored) or "json" (one JSON object per line).
# LOG_FORMAT=pretty
